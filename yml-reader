package com.example.configloader.service;

import com.example.configloader.github.GitHubService;
import com.example.configloader.model.OrderConfig;
import com.example.configloader.parser.JsonWriter;
import com.example.configloader.parser.YamlParser;
import org.springframework.stereotype.Service;

import java.io.InputStream;

@Service
public class ConfigLoaderService {

    private final GitHubService gitHubService;
    private final YamlParser yamlParser;
    private final JsonWriter jsonWriter;

    public ConfigLoaderService(GitHubService gitHubService,
                               YamlParser yamlParser,
                               JsonWriter jsonWriter) {
        this.gitHubService = gitHubService;
        this.yamlParser = yamlParser;
        this.jsonWriter = jsonWriter;
    }

    public void process(String branch) throws Exception {

        String repo = "your-org/order-config-repo";
        String path = "configs/orders/order-config.yml";

        InputStream is = gitHubService.fetchFile(repo, branch, path);

        OrderConfig config = yamlParser.parse(is);

        // 🔹 Generate dynamic filename
        String fileName = generateFileName(config);

        jsonWriter.write(config, fileName);

        System.out.println("Processed and written JSON: " + fileName);
    }

    private String generateFileName(OrderConfig config) {

        String serviceName = safe(config.getService().getName());
        String configId = safe(config.getService().getConfigId());

        return String.format("t24data-%s!%s.json", serviceName, configId);
    }

    private String safe(String value) {
        if (value == null || value.isEmpty()) {
            return "unknown";
        }

        // Remove unsafe characters for file systems
        return value.replaceAll("[^a-zA-Z0-9-_]", "_");
    }
}
