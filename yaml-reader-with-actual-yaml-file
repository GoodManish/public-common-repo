package com.example.configloader.runner;

import com.example.configloader.service.ConfigLoaderService;
import org.springframework.boot.CommandLineRunner;
import org.springframework.stereotype.Component;

@Component
public class JobRunner implements CommandLineRunner {

    private final ConfigLoaderService service;

    public JobRunner(ConfigLoaderService service) {
        this.service = service;
    }

    @Override
    public void run(String... args) throws Exception {

        String branch = "main";

        for (String arg : args) {
            if (arg.startsWith("--branch=")) {
                branch = arg.split("=")[1];
            }
        }

        service.process(branch);
    }
}
