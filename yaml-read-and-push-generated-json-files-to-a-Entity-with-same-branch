package com.example.configloader.github;

import org.eclipse.jgit.api.Git;
import org.eclipse.jgit.transport.UsernamePasswordCredentialsProvider;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.io.File;

@Service
public class GitService {

    @Value("${GITHUB_TOKEN}")
    private String token;

    private static final String USER = "x-access-token";

    public File cloneRepo(String repoUrl, String branch) throws Exception {

        File dir = new File("target/clone-repo");

        if (dir.exists()) {
            deleteDir(dir);
        }

        Git.cloneRepository()
                .setURI(repoUrl)
                .setBranch(branch)
                .setDirectory(dir)
                .setCredentialsProvider(new UsernamePasswordCredentialsProvider(USER, token))
                .call();

        return dir;
    }

    public void commitAndPush(File repoDir, String message) throws Exception {

        Git git = Git.open(repoDir);

        git.add().addFilepattern(".").call();

        git.commit()
                .setMessage(message)
                .call();

        git.push()
                .setCredentialsProvider(new UsernamePasswordCredentialsProvider(USER, token))
                .call();
    }

    private void deleteDir(File file) {
        if (file.isDirectory()) {
            for (File f : file.listFiles()) {
                deleteDir(f);
            }
        }
        file.delete();
    }
}


✅ 7. ConfigLoaderService (FULLY UPDATED FLOW)
package com.example.configloader.service;

import com.example.configloader.github.GitService;
import com.example.configloader.model.*;
import com.example.configloader.parser.JsonWriter;
import com.example.configloader.parser.YamlParser;
import org.springframework.stereotype.Service;

import java.io.File;
import java.util.Map;

@Service
public class ConfigLoaderService {

    private final YamlParser yamlParser;
    private final JsonWriter jsonWriter;
    private final GitService gitService;

    public ConfigLoaderService(YamlParser yamlParser,
                               JsonWriter jsonWriter,
                               GitService gitService) {
        this.yamlParser = yamlParser;
        this.jsonWriter = jsonWriter;
        this.gitService = gitService;
    }

    public void process(String branch) throws Exception {

        // 1. Parse local YAML
        RootConfig root = yamlParser.parse();

        // 2. Clone target repo
        String repoUrl = "https://github.com/your-org/Transact-Entity.git";
        File repoDir = gitService.cloneRepo(repoUrl, branch);

        String outputDir = repoDir.getAbsolutePath() + "/generated";

        // 3. Generate JSON files
        for (Entity entity : root.getEntities()) {

            String entityId = safe(entity.getEntityId());

            for (Application app : entity.getApplications()) {

                String appName = safe(app.getApplication());

                int index = 1;

                for (Map<String, Object> record : app.getRecords()) {

                    String recordId = extractId(record);

                    String fileName = String.format(
                            "t24data-%s!%s-%s-%d.json",
                            entityId,
                            appName,
                            recordId,
                            index++
                    );

                    jsonWriter.write(record, outputDir, fileName);
                }
            }
        }

        // 4. Commit & Push
        gitService.commitAndPush(repoDir, "Auto-generated JSON files");
    }

    private String extractId(Map<String, Object> record) {
        Object id = record.get("id");
        if (id == null) id = record.get("ID");
        return safe(id != null ? id.toString() : "unknown");
    }

    private String safe(String value) {
        if (value == null) return "unknown";
        return value.replaceAll("[^a-zA-Z0-9-_]", "_");
    }
}


